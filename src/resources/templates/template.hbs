<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rerpote Tasacion Lab</title>
</head>

<body>
    <div class="container">
    <h1 class="text-center" style="font-size: 12px;">{{ cabecera.solicitante }}</h1>
